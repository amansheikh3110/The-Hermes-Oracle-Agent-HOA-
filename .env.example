# =============================================================================
# Copy to .env and fill. Never commit .env.
# =============================================================================

OPENROUTER_API_KEY=

OPENROUTER_CHAT_MODEL=qwen/qwen3.6-plus:free

OPENROUTER_EMBEDDING_MODEL=nvidia/llama-nemotron-embed-vl-1b-v2:free
# If VL embeddings return empty rows for plain text, set a text-only fallback:
# OPENROUTER_EMBEDDING_FALLBACK_MODEL=openai/text-embedding-ada-002

OPENROUTER_HTTP_REFERER=https://openrouter.ai/
OPENROUTER_APP_TITLE=CWT Prediction Agent

APIFY_TOKEN=
APIFY_POLYMARKET_ACTOR=fatihtahta/polymarket-scraper-mo

KALSHI_API_KEY_ID=
KALSHI_PRIVATE_KEY_PATH=

CWT_DATA_DIR=./data
CHROMA_COLLECTION=cwt_events
LOG_LEVEL=INFO
